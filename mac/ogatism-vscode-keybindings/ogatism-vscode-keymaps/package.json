{
  "name": "ogatism-vscode-keymaps",
  "displayName": "ogatism-vscode-keymaps",
  "description": "my original keymaps",
  "version": "0.0.1",
  "repository": "https://github.com/ogaty/keymaps",
  "engines": {
    "vscode": "^1.76.0"
  },
  "categories": [
    "Keymaps"
  ],
  "contributes": {
    "keybindings": [
    {
        "key": "alt+cmd+left",
        "command": "workbench.action.navigateBack",
        "when": "canNavigateBack"
    },
    {
        "key": "ctrl+[Minus]",
        "command": "-workbench.action.navigateBack",
        "when": "canNavigateBack"
    },
    {
        "key": "cmd+[Minus]",
        "command": "-workbench.action.zoomOut"
    },
    {
        "key": "alt+cmd+right",
        "command": "workbench.action.navigateForward",
        "when": "canNavigateForward"
    }
    ]
  }
}
